[
    {
        "task": "get_exif",
        "comment": "",
        "params": {
            "input": "",
            "output": "h_w_exif.json"
        }
    },
    {
        "task": "get_image_pair_exhaustive",
        "comment": "",
        "params": {
            "input": "",
            "output": "image_pair.csv"
        }
    },

    {
        "task": "rotate_matching_find_best",
        "comment": "DeDoDe Detector-L + Descriptor-B (784x784, 4096 kp) rotation detection",
        "params": {
            "matcher": "DeDoDe",
            "input": {
                "image_pair": "image_pair.csv"
            },
            "output": {
                "keypoints": "_keypoints.h5",
                "descriptions": "_descriptions.h5",
                "matches": "_matches.h5",
                "image_pair_csv": "image_pair.csv"
            },
            "sufficient_matching_num": 512,
            "dedode_args": {
                "dedode_code_path": "__DEDODE_CODE_ROOT__",
                "detector_weights": "__DEDODE_DETECTOR_PATH__",
                "descriptor_weights": "__DEDODE_DESCRIPTOR_PATH__",
                "descriptor_type": "B",
                "num_keypoints": 4096,
                "H": 784,
                "W": 784
            },
            "keypoint_matching_args": {
                "match_method": "mnn",
                "mnn_threshold": 0.85,
                "min_matches": 10,
                "verbose": false
            }
        }
    },

    {
        "task": "matching",
        "comment": "DeDoDe Detector-L + Descriptor-B (784x784, 10000 kp)",
        "params": {
            "matcher": "DeDoDe",
            "input": {
                "image_pair": "image_pair.csv"
            },
            "output": {
                "keypoints": "keypoints_dedode_2.h5",
                "descriptions": "descriptions_dedode_2.h5",
                "matches": "matches_dedode_2.h5"
            },
            "dedode_args": {
                "dedode_code_path": "__DEDODE_CODE_ROOT__",
                "detector_weights": "__DEDODE_DETECTOR_PATH__",
                "descriptor_weights": "__DEDODE_DESCRIPTOR_PATH__",
                "descriptor_type": "B",
                "num_keypoints": 10000,
                "H": 784,
                "W": 784
            },
            "keypoint_matching_args": {
                "match_method": "mnn",
                "mnn_threshold": 0.85,
                "min_matches": 30,
                "verbose": false
            }
        }
    },
    {
        "task": "count_matching_num",
        "comment": "",
        "params": {
            "input": {
                "image_pair": "image_pair.csv",
                "matches": "matches_dedode_2.h5"
            },
            "output": "image_pair.csv"
        }
    },

    {
        "task": "matching",
        "comment": "aliked_LightGlue (imsize=1536, 8192 kp)",
        "params": {
            "matcher": "LightGlue",
            "extractor": "aliked",
            "input": {
                "image_pair": "image_pair.csv"
            },
            "output": {
                "keypoints": "keypoints_aliked_orig.h5",
                "descriptions": "descriptions_aliked_orig.h5",
                "matches": "matches_aliked_orig.h5"
            },
            "keypoint_detection_args": {
                "extractor_conf": {
                    "max_num_keypoints": 8192,
                    "detection_threshold": 0.01,
                    "nms_radius": 4
                },
                "preprocess_conf": {
                    "resize": 1536
                },
                "dtype": "float32"
            },
            "keypoint_matching_args": {
                "matcher_params": {
                    "width_confidence": -1,
                    "depth_confidence": -1,
                    "mp": true
                },
                "min_matches": 30,
                "verbose": false
            }
        }
    },

    {
        "task": "concat",
        "comment": "Concat DeDoDe + ALIKED original matches",
        "params": {
            "input": {
                "keypoints": [
                    "keypoints_dedode_2.h5",
                    "keypoints_aliked_orig.h5"
                ],
                "matches": [
                    "matches_dedode_2.h5",
                    "matches_aliked_orig.h5"
                ]
            },
            "output": {
                "keypoints": "keypoints_orig.h5",
                "matches": "matches_orig.h5"
            }
        }
    },
    {
        "task": "rem_less_match_pair",
        "comment": "",
        "params": {
            "input": "matches_orig.h5",
            "output": "matches_orig.h5",
            "th_matching_num": 100
        }
    },
    {
        "task": "count_matching_num",
        "comment": "",
        "params": {
            "input": {
                "image_pair": "image_pair.csv",
                "matches": "matches_orig.h5"
            },
            "output": "image_pair.csv"
        }
    },

    {
        "task": "sfm_mkpc",
        "comment": "",
        "params": {
            "input": {
                "keypoints": "keypoints_orig.h5",
                "matches": "matches_orig.h5"
            },
            "output": "mkpc_rect.json",
            "thresh": 0.15,
            "db_scan_param": {
                "eps": 0.05,
                "min_samples": 16
            },
            "mkpt_rect_parms": {
                "crop_scale": [1.05, 1.05],
                "inliner_rate_thresh": 0.2
            }
        }
    },

    {
        "task": "matching",
        "comment": "DeDoDe cropped (784x784, 10000 kp)",
        "params": {
            "matcher": "DeDoDe",
            "input": {
                "image_pair": "image_pair.csv",
                "rects": "mkpc_rect.json"
            },
            "output": {
                "keypoints": "keypoints_dedode_crop2.h5",
                "descriptions": "descriptions_dedode_crop2.h5",
                "matches": "matches_dedode_crop2.h5"
            },
            "dedode_args": {
                "dedode_code_path": "__DEDODE_CODE_ROOT__",
                "detector_weights": "__DEDODE_DETECTOR_PATH__",
                "descriptor_weights": "__DEDODE_DESCRIPTOR_PATH__",
                "descriptor_type": "B",
                "num_keypoints": 10000,
                "H": 784,
                "W": 784
            },
            "keypoint_matching_args": {
                "match_method": "mnn",
                "mnn_threshold": 0.85,
                "min_matches": 50,
                "verbose": false
            }
        }
    },

    {
        "task": "matching",
        "comment": "aliked_LightGlue cropped (imsize=1536, 8192 kp)",
        "params": {
            "matcher": "LightGlue",
            "extractor": "aliked",
            "input": {
                "image_pair": "image_pair.csv",
                "rects": "mkpc_rect.json"
            },
            "output": {
                "keypoints": "keypoints_aliked_crop.h5",
                "descriptions": "descriptions_aliked_crop.h5",
                "matches": "matches_aliked_crop.h5"
            },
            "keypoint_detection_args": {
                "extractor_conf": {
                    "max_num_keypoints": 8192,
                    "detection_threshold": 0.01,
                    "nms_radius": 4
                },
                "preprocess_conf": {
                    "resize": 1536
                },
                "dtype": "float32"
            },
            "keypoint_matching_args": {
                "matcher_params": {
                    "width_confidence": -1,
                    "depth_confidence": -1,
                    "mp": true
                },
                "min_matches": 50,
                "verbose": false
            }
        }
    },

    {
        "task": "concat",
        "comment": "Concat all original + cropped matches (DeDoDe + ALIKED ensemble)",
        "params": {
            "input": {
                "keypoints": [
                    "keypoints_orig.h5",
                    "keypoints_dedode_crop2.h5",
                    "keypoints_aliked_crop.h5"
                ],
                "matches": [
                    "matches_orig.h5",
                    "matches_dedode_crop2.h5",
                    "matches_aliked_crop.h5"
                ]
            },
            "output": {
                "keypoints": "keypoints.h5",
                "matches": "matches.h5"
            }
        }
    },
    {
        "task": "rem_less_match_pair",
        "comment": "",
        "params": {
            "input": "matches.h5",
            "output": "matches.h5",
            "th_matching_num": 100
        }
    },

    {
        "task": "ransac",
        "comment": "",
        "params": {
            "input": {
                "keypoints": "keypoints.h5",
                "matches": "matches.h5"
            },
            "output": {
                "matches": "matches.h5",
                "fms": "fms.pkl"
            },
            "min_matches": 0,
            "ransac_params": {
                "param1": 5,
                "param2": 0.9999,
                "maxIters": 50000
            }
        }
    },
    {
        "task": "count_matching_num",
        "comment": "",
        "params": {
            "input": {
                "image_pair": "image_pair.csv",
                "matches": "matches.h5"
            },
            "output": "image_pair.csv"
        }
    }
]
