                "num_keypoints": 4096,
                "H": 784,
                "W": 784
            },
            "keypoint_matching_args": {
                "lightglue_weights_path": "__DEDODEB_LIGHTGLUE_WEIGHTS__",
                "matcher_params": {
                    "width_confidence": 0.95,
                    "depth_confidence": 0.9,
                    "mp": true,
                    "filter_threshold": 0.1
                },
                "min_matches": 10,
                "verbose": false
            }
        }
